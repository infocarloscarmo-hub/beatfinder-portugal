# ───────────────────────────────────────────────────────────────
# Beatfinder Portugal — variáveis de ambiente
# Copia para .env.local e preenche os valores
# ───────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Chave service_role — SÓ no servidor. NUNCA expor no cliente / NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Segredo partilhado com o n8n para autenticar o endpoint /api/ingest
INGEST_API_KEY=gera-um-segredo-aleatorio-longo

# Segredo para revalidar cache via /api/revalidate (opcional)
REVALIDATE_SECRET=outro-segredo-aleatorio

# URL pública do site (usado em metadata/sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
